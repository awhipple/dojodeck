#!/usr/bin/env bash
# dojodeck — the SINGLE thing you add to Steam on the Deck.
#
# Loop: self-update -> sync every game in the manifest -> show the hub menu ->
#       launch the picked game -> back to the menu. You never leave this app.
#
# It updates ITSELF too: each sync pulls this repo (hub UI + this launcher +
# manifest). If the launcher file itself changed, it re-execs so the new logic
# takes effect immediately — no manual relaunch. Games + hub update every time you
# return to the menu; pushing a new dojodeck feature ships exactly like a new game.
#
# Runs as a normal host process and uses a bundled LÖVE AppImage (no flatpak
# sandbox), so reading game folders + git "just works". First run downloads and
# extracts LÖVE once into ./runtime/.
set -uo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
SELF="$HERE/$(basename "$0")"
GAMES="$HERE/games"
MANIFEST="$HERE/games.txt"
RUNTIME="$HERE/runtime"
LOVE="$RUNTIME/AppRun"

# Dev channel (optional). With a token hand-entered into ./devtoken (shown on
# the dojo's /admin/apps page), every launch ALSO pulls the LIVE working tree
# of each gamelab game from the dojo as a ready-to-run .love — no commit, no
# push. Dev copies live in ./devgames and show as "<slug> (dev)" menu rows;
# Y re-downloads one in place. Publishing to everyone still goes through git.
DEVGAMES="$HERE/devgames"
DEVTOKEN_FILE="$HERE/devtoken"
DEVINDEX="$DEVGAMES/index.tsv"     # slug<TAB>subtitle, as served at launch sync
DEV_BASE="${DOJODECK_DEV_URL:-https://api.whipple.ninja}"

LIST="/tmp/dojodeck.list"
OUT="/tmp/dojodeck.out"
PLAYED="$HERE/lastplayed.tsv"   # slug<TAB>epoch, most-recent-first menu sort
REEXECS="${DOJODECK_REEXECS:-0}"   # guard against pathological re-exec loops

LOVE_URL="https://github.com/love2d/love/releases/download/11.5/love-11.5-x86_64.AppImage"

note() { printf '\033[36m[dojodeck]\033[0m %s\n' "$*"; }

ensure_runtime() {
  [ -x "$LOVE" ] && return 0
  note "first run: fetching LÖVE 11.5 AppImage…"
  local tmp="/tmp/love-dojodeck.AppImage"
  curl -fL "$LOVE_URL" -o "$tmp" || { note "download failed (no network?)"; return 1; }
  chmod +x "$tmp"
  ( cd /tmp && rm -rf squashfs-root && "$tmp" --appimage-extract >/dev/null )
  rm -rf "$RUNTIME"; mv /tmp/squashfs-root "$RUNTIME"
  rm -f "$tmp"
  note "LÖVE installed into runtime/"
}

# Pull this repo. If the launcher file itself changed, re-exec so the update
# applies now. Hash equality after pulling prevents an infinite re-exec loop.
self_update() {
  local before after
  before="$(sha1sum "$SELF" 2>/dev/null || echo a)"
  git -C "$HERE" pull --ff-only --quiet 2>/dev/null || true
  after="$(sha1sum "$SELF" 2>/dev/null || echo b)"
  if [ "$before" != "$after" ] && [ "$REEXECS" -lt 5 ]; then
    note "launcher updated — restarting"
    DOJODECK_REEXECS="$((REEXECS + 1))" exec "$SELF" "$@"
  fi
}

sync_games() {
  mkdir -p "$GAMES"
  [ -f "$MANIFEST" ] || return 0
  while IFS=$' \t' read -r slug url _; do
    [ -z "${slug:-}" ] && continue
    case "$slug" in \#*) continue ;; esac
    if [ -d "$GAMES/$slug/.git" ]; then
      git -C "$GAMES/$slug" pull --ff-only --quiet 2>/dev/null || note "  $slug: pull failed"
    else
      note "  cloning $slug…"
      git clone --quiet "$url" "$GAMES/$slug" 2>/dev/null || note "  $slug: clone failed"
    fi
  done < "$MANIFEST"
}

dev_token() {  # echo the trimmed dev-channel token, or nothing
  [ -s "$DEVTOKEN_FILE" ] || return 0
  tr -d ' \t\r\n' < "$DEVTOKEN_FILE"
}

# Dev channel: fetch the dojo's list of live working trees and download each as
# a .love into devgames/. Soft-fail (offline / server down / bad token → keep
# whatever local copies exist). Games the server no longer lists are dropped.
sync_dev_games() {
  local tok; tok="$(dev_token)"
  [ -n "$tok" ] || return 0
  mkdir -p "$DEVGAMES"
  local list
  if ! list="$(curl -fsS --max-time 15 "$DEV_BASE/$tok/api/deck/games")"; then
    note "dev channel: can't reach the dojo — keeping local dev copies"
    return 0
  fi
  : > "$DEVINDEX.tmp"
  local slug sub
  while IFS=$'\t' read -r slug sub; do
    [ -n "${slug:-}" ] || continue
    case "$slug" in *[!a-zA-Z0-9_-]*) continue ;; esac    # server slugs are plain names
    note "  dev-pulling $slug…"
    if curl -fsS --max-time 60 "$DEV_BASE/$tok/api/deck/game/$slug.love" \
         -o "$DEVGAMES/$slug.love.tmp"; then
      mv "$DEVGAMES/$slug.love.tmp" "$DEVGAMES/$slug.love"
      printf '%s\t%s\n' "$slug" "$sub" >> "$DEVINDEX.tmp"
    else
      rm -f "$DEVGAMES/$slug.love.tmp"
      note "  $slug: dev pull failed"
      # keep an existing copy in the menu rather than hiding it
      [ -f "$DEVGAMES/$slug.love" ] && printf '%s\t%s\n' "$slug" "${sub:-dev}" >> "$DEVINDEX.tmp"
    fi
  done <<< "$list"
  mv "$DEVINDEX.tmp" "$DEVINDEX"
  local f base
  for f in "$DEVGAMES"/*.love; do
    [ -f "$f" ] || continue
    base="$(basename "$f" .love)"
    awk -F'\t' -v s="$base" '$1==s{found=1} END{exit !found}' "$DEVINDEX" || rm -f "$f"
  done
}

# last-opened bookkeeping (so the menu sorts most-recently-played first)
played_ts() {  # echo epoch for a slug, or 0
  awk -F'\t' -v s="$1" '$1==s{v=$2} END{print v+0}' "$PLAYED" 2>/dev/null || echo 0
}
record_played() {
  local s="$1" now tmp; now="$(date +%s)"; tmp="$PLAYED.tmp"
  if [ -f "$PLAYED" ]; then awk -F'\t' -v s="$s" '$1!=s' "$PLAYED" > "$tmp"; else : > "$tmp"; fi
  printf '%s\t%s\n' "$s" "$now" >> "$tmp"
  mv "$tmp" "$PLAYED"
}

build_list() {
  local tmp="$LIST.tmp"; : > "$tmp"
  for d in "$GAMES"/*/; do
    [ -f "${d}main.lua" ] || continue
    local slug sub ts
    slug="$(basename "$d")"
    sub="$(git -C "$d" log -1 --format='%h  %cr' 2>/dev/null || echo '')"
    ts="$(played_ts "$slug")"
    printf '%s\t%s\t%s\t%s\n' "$ts" "$slug" "${d%/}" "$sub" >> "$tmp"
  done
  # Dev-channel rows: a 5th column carries the re-download URL, which is what
  # makes the hub's Y re-sync curl instead of git-pull for these.
  local tok; tok="$(dev_token)"
  if [ -n "$tok" ] && [ -f "$DEVINDEX" ]; then
    local dslug dsub dlove dts
    while IFS=$'\t' read -r dslug dsub; do
      dlove="$DEVGAMES/$dslug.love"
      [ -f "$dlove" ] || continue
      dts="$(played_ts "$dslug (dev)")"
      printf '%s\t%s\t%s\t%s\t%s\n' "$dts" "$dslug (dev)" "$dlove" "$dsub" \
        "$DEV_BASE/$tok/api/deck/game/$dslug.love" >> "$tmp"
    done < "$DEVINDEX"
  fi
  # sort by last-played desc, then slug asc for never-played; drop the ts column
  sort -t"$(printf '\t')" -k1,1nr -k2,2 "$tmp" | cut -f2- > "$LIST"
  rm -f "$tmp"
}

# Steam launches non-Steam shortcuts with LD_PRELOAD pointing at BOTH the 32- and
# 64-bit gameoverlayrenderer.so. Our LÖVE is 64-bit, so ld.so can't load the 32-bit
# one and spews "wrong ELF class: ELFCLASS32: ignored" — which gamescope draws over
# the screen on load. Drop the 32-bit entries (keep any 64-bit ones) so it's silent.
sanitize_preload() {
  [ -n "${LD_PRELOAD:-}" ] || return 0
  local cleaned="" p oldifs="$IFS"
  IFS=': '
  for p in $LD_PRELOAD; do
    case "$p" in
      ""|*ubuntu12_32*|*lib32*|*/i386*|*/32/*) ;;     # skip 32-bit preloads
      *) cleaned="${cleaned:+$cleaned:}$p" ;;
    esac
  done
  IFS="$oldifs"
  export LD_PRELOAD="$cleaned"
}
sanitize_preload

# Single instance: if dojodeck is already running, don't start a second copy (two
# launchers could each spawn a game → duplicates). Skip on self-update re-exec,
# which keeps fd 9 (and thus the lock) open across exec.
LOCK="$HERE/.dojodeck.lock"
if [ "${DOJODECK_REEXECS:-0}" = "0" ] && command -v flock >/dev/null 2>&1; then
  exec 9>"$LOCK"
  flock -n 9 || { note "dojodeck is already running — exiting this instance"; exit 0; }
fi

ensure_runtime || true

# Full update happens ONCE, on launch: self-update (hub + launcher + manifest;
# re-execs if the launcher changed) then pull every game. This is the slow part,
# so we do NOT repeat it on every menu return — individual games are refreshed
# in-place from the hub (Y = re-sync the highlighted game, with a spinner).
note "launch sync…"
self_update "$@"
sync_games
sync_dev_games

while true; do
  build_list   # local-only: refresh commit lines + most-recently-played order (fast, no network)

  : > "$OUT"
  selfver="$(git -C "$HERE" log -1 --format='%h  %cr' 2>/dev/null || echo '')"
  "$LOVE" "$HERE/hub" --list "$LIST" --out "$OUT" --version "$selfver" 2>/dev/null || true

  IFS=$'\t' read -r action _slug path < "$OUT" 2>/dev/null || action="QUIT"
  case "${action:-QUIT}" in
    PLAY)
      # One game at a time. Kill any stray game process, let the launch button
      # physically release (so it doesn't bleed into the game as a quit), then run
      # the game in the FOREGROUND — this blocks until it exits, so the menu can
      # never reappear or launch a second copy while a game is running.
      pkill -f "$GAMES/" 2>/dev/null || true
      pkill -f "$DEVGAMES/" 2>/dev/null || true
      sleep 0.3
      note "launching $_slug"
      record_played "$_slug"                # bump to top of the menu for next time
      "$LOVE" "$path" 2>/dev/null || true   # returns here only when the game quits
      sleep 0.3                             # settle so a held quit doesn't re-trigger
      ;;
    SYNC) : ;;          # legacy/no-op: the hub now pulls in-place, so just redraw
    *)    break ;;       # QUIT / empty -> back to Steam
  esac
done
