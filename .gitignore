# Bundled LÖVE runtime (downloaded + extracted on first launch)
runtime/

# Games are cloned here at runtime from the manifest (each its own repo)
games/

# Per-device "last opened" state (drives the menu sort)
lastplayed.tsv

# Dev channel: the hand-entered token + the .love working-tree snapshots it pulls
devtoken
devgames/

# Single-instance lock (runtime)
.dojodeck.lock

# OS cruft
.DS_Store
